<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Crear cuenta</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <%- include('../partials/nav') %>
        <div class="container">
            <div class="card" style="max-width: 500px; margin: 0 auto;">
                <h1>Crear cuenta</h1>
                <br>
                <% if (typeof error !=='undefined' ) { %>
                    <p style="color: #c5522a; margin-bottom: 15px;">
                        <%= error %>
                    </p>
                    <% } %>
                        <form method="POST" action="/auth/registro">
                            <label>Nombre:</label>
                            <input type="text" name="nombre" required>
                            <label>Email:</label>
                            <input type="email" name="email" required>
                            <label>Contraseña:</label>
                            <div style="position: relative;">
                                <input type="password" name="password" id="password" required>
                                <span onclick="togglePassword()"
                                    style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); cursor: pointer; color: #888;">👁</span>
                            </div>
                            <br>
                            <button type="submit">Crear cuenta</button>
                        </form>
                        <br>
                        <p style="text-align: center; color: #888;">¿Ya tenés cuenta? <a href="/auth/login"
                                style="color: #c5522a;">Ingresá</a></p>
            </div>
        </div>
        <script>
            function togglePassword() {
                const input = document.getElementById('password')
                input.type = input.type === 'password' ? 'text' : 'password'
            }
        </script>
</body>

</html>