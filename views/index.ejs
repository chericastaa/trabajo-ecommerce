<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Ecommerce</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <%- include('partials/nav') %>
        <div class="container">
            <h1>Bienvenido a la tienda</h1>
            <p style="color: #888; margin-bottom: 30px;">Elegí el producto que va con vos.</p>
            <% if (productos.length===0) { %>
                <p>No hay productos disponibles</p>
                <% } else { %>
                    <div class="productos-grid">
                        <% productos.forEach(producto=> { %>
                            <a href="/productos/<%= producto.id %>" class="producto-card-link">
                                <div class="producto-card">
                                    <% if (producto.imagen) { %>
                                        <img src="<%= producto.imagen %>" alt="<%= producto.nombre %>"
                                            class="producto-img">
                                        <% } else { %>
                                            <div class="producto-img-placeholder"></div>
                                            <% } %>
                                                <div class="producto-info">
                                                    <h2>
                                                        <%= producto.nombre %>
                                                    </h2>
                                                    <% if (producto.descripcion) { %>
                                                        <p class="producto-desc">
                                                            <%= producto.descripcion.substring(0, 80) %>...
                                                        </p>
                                                        <% } %>
                                                            <p class="precio">$<%= producto.precio %>
                                                            </p>
                                                </div>
                                </div>
                            </a>
                            <% }) %>
                    </div>
                    <% } %>
        </div>
        <footer>© 2026 Mi Tienda</footer>
</body>

</html>